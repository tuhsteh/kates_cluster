# Managed by Ansible — do not edit manually
# Selenium Grid 4 Helm values for k3s on ARM64 Raspberry Pi 4B

global:
  seleniumGrid:
    imageRegistry: "{{ selenium_grid_registry }}"
    imageTag: "{{ selenium_grid_image_tag }}"
    nodesImageTag: "{{ selenium_grid_image_tag }}"
    # videoImageTag is separate from imageTag — ffmpeg-tagged image is ARM64 multi-arch
    videoImageTag: "{{ selenium_grid_video_image_tag }}"

hub:
  serviceType: NodePort
  nodePort: {{ selenium_grid_hub_nodeport }}
  resources:
    requests:
      memory: "512Mi"
      cpu: "200m"
    limits:
      memory: "1Gi"
      cpu: "1000m"
  basicAuth:
    enabled: true
    username: "{{ selenium_grid_basic_auth_username }}"
    password: "{{ selenium_grid_basic_auth_password }}"

chromeNode:
  enabled: true
  imageName: node-chromium
  replicas: 0
  maxSessions: {{ selenium_grid_node_max_sessions }}
  # REQUIRED: k8s pods default to 64MB /dev/shm — Chromium crashes without at least 1Gi
  dshmVolumeSizeLimit: "{{ selenium_grid_node_shm_size }}"
  resources:
    requests:
      cpu: "{{ selenium_grid_node_cpu_request }}"
      memory: "{{ selenium_grid_node_memory_request }}"
    limits:
      cpu: "{{ selenium_grid_node_cpu_limit }}"
      memory: "{{ selenium_grid_node_memory_limit }}"
  topologySpreadConstraints:
    - maxSkew: 1
      topologyKey: kubernetes.io/hostname
      whenUnsatisfiable: ScheduleAnyway
      labelSelector:
        matchLabels:
          app.kubernetes.io/name: selenium-grid-selenium-node-chrome

firefoxNode:
  enabled: false

edgeNode:
  enabled: false

videoRecorder:
  enabled: "{{ 'true' if selenium_grid_video_enabled else 'false' }}"
  targetFolder: "/videos"
  # Reduce FFmpeg load on Pi 4B — software-only encode, no GPU
  extraEnvironmentVariables:
    - name: SE_FRAME_RATE
      value: "{{ selenium_grid_video_frame_rate }}"
    - name: SE_SCREEN_WIDTH
      value: "{{ selenium_grid_video_width }}"
    - name: SE_SCREEN_HEIGHT
      value: "{{ selenium_grid_video_height }}"
  extraVolumes:
    - name: selenium-storage
      persistentVolumeClaim:
        claimName: {{ selenium_grid_storage_pvc_name }}
  extraVolumeMounts:
    - name: selenium-storage
      mountPath: /videos
      subPath: videos
  resources:
    requests:
      memory: "128Mi"
      cpu: "100m"
    limits:
      memory: "512Mi"
      cpu: "500m"

videoManager:
  enabled: "{{ 'true' if selenium_grid_video_manager_enabled else 'false' }}"
  serviceType: NodePort
  nodePort: {{ selenium_grid_video_manager_nodeport }}
  extraVolumes:
    - name: selenium-storage
      persistentVolumeClaim:
        claimName: {{ selenium_grid_storage_pvc_name }}
  extraVolumeMounts:
    - name: selenium-storage
      mountPath: /srv

autoscaling:
  enabled: true
  scalingType: job
  scaledOptions:
    minReplicaCount: 0
    maxReplicaCount: {{ selenium_grid_node_max_replicas }}
    pollingInterval: 10
