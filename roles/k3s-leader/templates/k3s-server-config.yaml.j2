# Managed by Ansible — do not edit manually
# k3s server configuration for {{ inventory_hostname }}

# --- Networking ---
cluster-cidr: "10.42.0.0/16"
service-cidr: "10.43.0.0/16"
cluster-dns: "10.43.0.10"

# --- CNI backend ---
flannel-backend: "vxlan"

# --- Disable unneeded bundled components ---
disable:
  - traefik
  - servicelb

# --- TLS SANs for external kubectl access ---
tls-san:
  - "kate0.local"
  - "{{ ansible_default_ipv4.address }}"

# --- Node IP (use primary wired interface) ---
node-ip: "{{ ansible_default_ipv4.address }}"

# --- Storage ---
# Store all k3s data on the m.2 SSD to protect the SD card from write wear
data-dir: /mnt/ssd/k3s

# --- kubelet arguments ---
# WARNING: root-dir moves emptyDir volumes and pod sandbox storage to SSD.
# Some CNI plugins hardcode /var/lib/kubelet — test CNI compatibility before relying on this.
kubelet-arg:
  - "container-log-max-size=10Mi"
  - "container-log-max-files=3"
  - "root-dir=/mnt/ssd/k3s/agent/kubelet"
