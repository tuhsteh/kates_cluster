# Managed by Ansible — do not edit manually
apiVersion: apps/v1
kind: Deployment
metadata:
  name: selenium-media-filebrowser
  namespace: {{ selenium_media_namespace }}
  labels:
    app.kubernetes.io/name: selenium-media-filebrowser
    app.kubernetes.io/component: file-browser
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: selenium-media-filebrowser
  template:
    metadata:
      labels:
        app.kubernetes.io/name: selenium-media-filebrowser
        app.kubernetes.io/component: file-browser
    spec:
      containers:
        - name: filebrowser
          image: {{ selenium_media_filebrowser_image }}
          # --noauth: no login required for team-internal cluster access
          command:
            - filebrowser
            - --noauth
            - --root=/srv
            - --port=80
            - --address=0.0.0.0
          ports:
            - containerPort: 80
          volumeMounts:
            - name: media-storage
              mountPath: /srv
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "256Mi"
              cpu: "200m"
      volumes:
        - name: media-storage
          persistentVolumeClaim:
            claimName: {{ selenium_media_pvc_name }}
